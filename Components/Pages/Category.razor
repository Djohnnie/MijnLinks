@page "/category/{CategoryName}"
@inject LinkService LinkService

<PageTitle>MijnLinks - @CategoryName</PageTitle>

<div class="page-header">
    <MudText Typo="Typo.h4" Class="page-title">
        <MudIcon Icon="@Icons.Material.Filled.Folder" Class="mr-2" Style="vertical-align: middle;" />
        @Uri.UnescapeDataString(CategoryName)
    </MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-1">
        @(_links.Count) link@(_links.Count != 1 ? "s" : "") in deze categorie
    </MudText>
</div>

@if (_loading)
{
    <div class="d-flex justify-center mt-16">
        <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="Color.Primary" />
    </div>
}
else if (_links.Count == 0)
{
    <MudAlert Severity="Severity.Info" Class="mt-4" Variant="Variant.Outlined">Geen links gevonden in deze categorie.</MudAlert>
}
else
{
    <MudGrid Spacing="2" Class="mt-2 tile-grid">
        @for (var i = 0; i < _links.Count; i++)
        {
            var link = _links[i];
            var delay = i;
            <MudItem xs="6" sm="6" md="4" lg="3" Style="@($"animation-delay: {delay * 60}ms")">
                <LinkTile Link="link" Index="delay" />
            </MudItem>
        }
    </MudGrid>
}

@code 
{
    [Parameter]
    public string CategoryName { get; set; } = string.Empty;

    private List<Link> _links = [];
    private bool _loading = true;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        var decoded = Uri.UnescapeDataString(CategoryName);
        _links = await LinkService.GetLinksByCategoryAsync(decoded);
        _loading = false;
    }
}